# config.env - Copy this to config.env and fill in your values
# Do NOT commit config.env to source control

# AWS region to deploy into
REGION="us-west-2"

# S3 bucket used to stage Lambda zip artifacts
# Optional — if left blank, a bucket named "<function-name>-deploy-<account-id>"
# will be auto-created on first deploy and auto-deleted by cleanup.sh
BUCKET_NAME=""

# Name of the Lambda function to create or update
FUNCTION_NAME="my-cicd-lambda"

# IAM role name for Lambda execution (will be created if it doesn't exist)
ROLE_NAME="lambda-basic-execution-role"
